# =============================================================
# .env.example — Environment variable reference
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# The LOCAL values work out-of-the-box with docker-compose.yml.
# The HOSTED values (commented out below each setting) are what
# you would set when deploying to a cloud environment.
#
# The recommended production cloud is Microsoft Azure; alternative
# providers are listed for each service.
#
# NEVER commit .env to source control — it may contain secrets.
# .env is listed in .gitignore for this reason.
# =============================================================


# =============================================================
# PostgreSQL — primary relational database
# =============================================================

# Local (Docker):
POSTGRES_URL=postgresql+asyncpg://postgres:secret@localhost:5432/ecommerce

# Hosted alternatives (uncomment one and fill in your credentials):
# Azure Database for PostgreSQL — Flexible Server:
# POSTGRES_URL=postgresql+asyncpg://<user>:<password>@<server>.postgres.database.azure.com:5432/ecommerce?ssl=require
#
# Google Cloud SQL:
# POSTGRES_URL=postgresql+asyncpg://<user>:<password>@<cloud-sql-ip>:5432/ecommerce
#
# Supabase:
# POSTGRES_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# Neon (serverless Postgres, free tier available):
# POSTGRES_URL=postgresql+asyncpg://<user>:<password>@<host>.neon.tech/ecommerce?sslmode=require


# =============================================================
# Valkey — in-memory cache, session store, rate limiter
#
# Valkey is a BSD-licensed open-source fork of Redis.
# All Redis-compatible clients and hosted services work with it.
# =============================================================

# Local (Docker):
REDIS_URL=redis://localhost:6379

# Hosted alternatives (uncomment one):
# Azure Cache for Redis (TLS on port 6380):
# REDIS_URL=rediss://<user>:<access-key>@<name>.redis.cache.windows.net:6380
#
# Upstash (serverless, generous free tier):
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
#
# Aiven for Valkey:
# REDIS_URL=rediss://default:<password>@<host>.aivencloud.com:<port>


# =============================================================
# Elasticsearch — product search engine
#
# Azure does not offer a first-party managed Elasticsearch.
# The official "Microsoft-cloud-hosted" path is Elastic Cloud
# on the Azure Marketplace, which runs on Azure infrastructure
# and is operated by Elastic.
# =============================================================

# Local (Docker):
ELASTICSEARCH_URL=http://localhost:9200

# Hosted alternatives (uncomment one):
# Elastic Cloud on Azure — basic auth:
# ELASTICSEARCH_URL=https://<deployment>.es.<region>.azure.elastic-cloud.com:9243
# ES_USERNAME=elastic
# ES_PASSWORD=<your-password>
#
# Elastic Cloud on Azure — API key (preferred over basic auth in production):
# ELASTICSEARCH_URL=https://<deployment>.es.<region>.azure.elastic-cloud.com:9243
# ES_API_KEY=<base64-api-key-from-the-elastic-cloud-ui>
#
# Bonsai (managed Elasticsearch, good for small projects):
# ELASTICSEARCH_URL=https://<host>.bonsaisearch.net
# ES_USERNAME=<bonsai-access-key>
# ES_PASSWORD=<bonsai-access-secret>


# =============================================================
# Object storage — Azure Blob Storage
#
# Local: Azurite (Microsoft's official Azure Blob emulator) in Docker
# Production: Azure Blob Storage in your Azure subscription
#
# A single connection string switches between the two —
# the same azure-storage-blob SDK is used either way.
# =============================================================

# Local (Azurite — well-known dev connection string published by Microsoft):
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER=product-images

# Production (uncomment and replace AccountName/AccountKey with your real values):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-storage-account>;AccountKey=<your-storage-account-key>;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=product-images


# =============================================================
# RabbitMQ — message queue for async post-order tasks
# =============================================================

# Local (Docker):
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Hosted alternatives (uncomment one):
# CloudAMQP — managed RabbitMQ, available as an Azure Marketplace plan:
# RABBITMQ_URL=amqps://<user>:<password>@<host>.cloudamqp.com/<vhost>
#
# Self-hosted on Azure Kubernetes Service (AKS):
# RABBITMQ_URL=amqps://<user>:<password>@rabbitmq.<namespace>.svc.cluster.local:5671/
#
# Note: Azure Service Bus uses a different SDK (azure-servicebus) and
# is not a drop-in for aio_pika. Switching would require rewriting
# queue.py and order_worker.py.


# =============================================================
# Application settings
# =============================================================

APP_ENV=local   # Change to "production" when deploying

# Used for signing session tokens. Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
