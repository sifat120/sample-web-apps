# =============================================================
# .env.example — Environment variable reference
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# The LOCAL values work out-of-the-box with docker-compose.yml.
# The HOSTED values (commented out below each setting) are what
# you would set when deploying to a cloud environment.
#
# NEVER commit .env to source control — it may contain secrets.
# .env is listed in .gitignore for this reason.
# =============================================================


# =============================================================
# PostgreSQL — primary relational database
# =============================================================

# Local (Docker):
POSTGRES_URL=postgresql+asyncpg://postgres:secret@localhost:5432/ecommerce

# Hosted alternatives (uncomment one and fill in your credentials):
# AWS RDS:
# POSTGRES_URL=postgresql+asyncpg://<user>:<password>@<rds-endpoint>.rds.amazonaws.com:5432/ecommerce
#
# Google Cloud SQL:
# POSTGRES_URL=postgresql+asyncpg://<user>:<password>@<cloud-sql-ip>:5432/ecommerce
#
# Supabase:
# POSTGRES_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# Neon (serverless Postgres, free tier available):
# POSTGRES_URL=postgresql+asyncpg://<user>:<password>@<host>.neon.tech/ecommerce?sslmode=require


# =============================================================
# Valkey — in-memory cache, session store, rate limiter
#
# Valkey is a BSD-licensed open-source fork of Redis.
# All Redis-compatible clients and hosted services work with it.
# =============================================================

# Local (Docker):
REDIS_URL=redis://localhost:6379

# Hosted alternatives (uncomment one):
# AWS ElastiCache for Valkey (TLS required in production):
# REDIS_URL=rediss://default:<auth-token>@<cluster-name>.cache.amazonaws.com:6379
#
# Upstash (serverless, generous free tier):
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
#
# Aiven for Valkey:
# REDIS_URL=rediss://default:<password>@<host>.aivencloud.com:<port>


# =============================================================
# Elasticsearch — product search engine
# =============================================================

# Local (Docker):
ELASTICSEARCH_URL=http://localhost:9200

# Hosted alternatives (uncomment one):
# Elastic Cloud (official managed service):
# ELASTICSEARCH_URL=https://<deployment-id>.es.io:9243
# ES_USERNAME=elastic
# ES_PASSWORD=<your-password>
#
# AWS OpenSearch (open-source Elasticsearch fork, fully managed):
# ELASTICSEARCH_URL=https://<domain>.<region>.es.amazonaws.com
#
# Bonsai (simpler managed Elasticsearch, good for small projects):
# ELASTICSEARCH_URL=https://<user>:<pass>@<host>.bonsaisearch.net


# =============================================================
# Object storage — product images
#
# Local: MinIO running in Docker (S3-compatible API)
# Production: AWS S3 (or any S3-compatible service)
#
# The only difference is STORAGE_ENDPOINT_URL:
#   - Set it for local MinIO so boto3 knows to use localhost
#   - Remove it (or leave blank) for AWS S3 — boto3 auto-targets S3
# =============================================================

# Local (MinIO via Docker):
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=product-images
STORAGE_REGION=us-east-1

# Hosted — AWS S3 (uncomment and remove STORAGE_ENDPOINT_URL):
# STORAGE_ENDPOINT_URL=
# STORAGE_ACCESS_KEY=AKIA...
# STORAGE_SECRET_KEY=<your-secret-access-key>
# STORAGE_BUCKET=my-company-product-images-prod
# STORAGE_REGION=us-east-1
#
# Hosted — Cloudflare R2 (S3-compatible, no egress fees):
# STORAGE_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=<r2-access-key-id>
# STORAGE_SECRET_KEY=<r2-secret-access-key>
# STORAGE_BUCKET=product-images
# STORAGE_REGION=auto


# =============================================================
# RabbitMQ — message queue for async post-order tasks
# =============================================================

# Local (Docker):
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Hosted alternatives (uncomment one):
# CloudAMQP (managed RabbitMQ, free tier available):
# RABBITMQ_URL=amqps://<user>:<password>@<host>.cloudamqp.com/<vhost>
#
# AWS MQ (managed RabbitMQ, AMQP-compatible — no code changes needed):
# RABBITMQ_URL=amqps://<user>:<password>@<broker-id>.mq.<region>.amazonaws.com:5671
#
# Note: AWS SQS is NOT compatible with the AMQP protocol used here.
# To use SQS, the queue.py and order_worker.py files would need to be
# rewritten to use boto3's SQS client instead of aio-pika.


# =============================================================
# Application settings
# =============================================================

APP_ENV=local   # Change to "production" when deploying

# Used for signing session tokens. Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
